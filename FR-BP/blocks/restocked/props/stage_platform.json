{
    "format_version": "1.21.30",
    "minecraft:block": {
        "description": {
            "identifier": "fr:stage_platform",
            "states": {
                "fr:visible": [true, false]
            },
            "menu_category": {
                "category": "construction"
            },
            "traits": {
                "minecraft:placement_direction": {
                    "enabled_states": [
                        "minecraft:cardinal_direction"
                    ]
                }
            }
        },
        "components": {
            "minecraft:geometry": "geometry.fr_animatronic_platform",
            "minecraft:material_instances": {
                "*": {
                    "texture": "fr_platform",
                    "render_method": "alpha_test"
                }
            },
            "minecraft:collision_box": {
                "origin": [
                    -8,
                    0,
                    -8
                ],
                "size": [
                    16,
                    2,
                    16
                ]
            },
            "minecraft:selection_box": {
                "origin": [
                    -8,
                    0,
                    -8
                ],
                "size": [
                    16,
                    2,
                    16
                ]
            },
            "minecraft:light_dampening": 0,
            "minecraft:tick": {
                "interval_range": [10, 10],
                "looping": true
            },
            "minecraft:custom_components": [
                "fr:platform_component"
            ]
        },
        "permutations": [
            {
                "condition": "q.block_state('fr:visible') == false",
                "components": {
                    "minecraft:geometry": "geometry.inv_cube",
                    "minecraft:material_instances": {
                        "*": {
                            "texture": "fr_platform",
                            "render_method": "alpha_test"
                        }
                    },
                    "minecraft:collision_box": {
                        "origin": [
                            -8,
                            0,
                            -8
                        ],
                        "size": [
                            16,
                            0.5,
                            16
                        ]
                    },
                    "minecraft:selection_box": {
                        "origin": [
                            -8,
                            0,
                            -8
                        ],
                        "size": [
                            16,
                            2,
                            16
                        ]
                    }
                }
            },
            {
                "condition": "q.block_state('minecraft:cardinal_direction') == 'north'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [
                            0,
                            180,
                            0
                        ]
                    }
                }
            },
            {
                "condition": "q.block_state('minecraft:cardinal_direction') == 'west'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [
                            0,
                            -90,
                            0
                        ]
                    }
                }
            },
            {
                "condition": "q.block_state('minecraft:cardinal_direction') == 'south'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [
                            0,
                            0,
                            0
                        ]
                    }
                }
            },
            {
                "condition": "q.block_state('minecraft:cardinal_direction') == 'east'",
                "components": {
                    "minecraft:transformation": {
                        "rotation": [
                            0,
                            90,
                            0
                        ]
                    }
                }
            }
        ]
    }
}