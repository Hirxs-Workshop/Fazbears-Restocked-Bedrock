{
  "format_version": "1.21.0",
  "minecraft:block": {
    "description": {
      "identifier": "fr:chica_cutout",
      "menu_category": {
        "category": "construction"
      },
      "states": {
        "fr:advanced_rot": {
          "values": {
            "min": 0,
            "max": 15
          }
        }
      },
      "traits": {
        "minecraft:placement_position": {
          "enabled_states": ["minecraft:block_face"]
        }
      }
    },
    "components": {
      "minecraft:geometry": {
        "identifier": "geometry.character_cutout",
        "bone_visibility": {
          "up_0": "q.block_state('minecraft:block_face') == 'up' && !math.mod(q.block_state('fr:advanced_rot'), 4)",
          "up_22_5": "q.block_state('minecraft:block_face') == 'up' && !math.mod(q.block_state('fr:advanced_rot') - 1, 4)",
          "up_45": "q.block_state('minecraft:block_face') == 'up' && !math.mod(q.block_state('fr:advanced_rot') - 2, 4)",
          "up_67_5": "q.block_state('minecraft:block_face') == 'up' && !math.mod(q.block_state('fr:advanced_rot') - 3, 4)",
          "side": "q.block_state('minecraft:block_face') != 'up'"
        }
      },
      "minecraft:collision_box": false,
      "minecraft:selection_box": {
	"origin": [-3, 0, -3],
	"size": [6, 16, 6]
      },
      "minecraft:material_instances": {
        "*": {
          "texture": "fr_chica_cutout",
          "render_method": "alpha_test",
          "face_dimming": false,
          "ambient_occlusion": true
        }
      },
      "fr:advanced_rotation": {}
    },
    "permutations": [
      {
        "condition": "q.block_state('fr:advanced_rot') >= 0 || q.block_state('minecraft:block_face') == 'north'",
        "components": {
          "minecraft:transformation": {
            "rotation": [0, 0, 0],
            "scale": [2, 2, 2],
            "translation": [0, 0.5, 0]
          }
        }
      },
      {
        "condition": "q.block_state('fr:advanced_rot') >= 4 || q.block_state('minecraft:block_face') == 'east'",
        "components": {
          "minecraft:transformation": {
            "rotation": [0, -90, 0],
            "scale": [2, 2, 2],
            "translation": [0, 0.5, 0]
          }
        }
      },
      {
        "condition": "q.block_state('fr:advanced_rot') >= 8 || q.block_state('minecraft:block_face') == 'south'",
        "components": {
          "minecraft:transformation": {
            "rotation": [0, 180, 0],
            "scale": [2, 2, 2],
            "translation": [0, 0.5, 0]
          }
        }
      },
      {
        "condition": "q.block_state('fr:advanced_rot') >= 12 || q.block_state('minecraft:block_face') == 'west'",
        "components": {
          "minecraft:transformation": {
            "rotation": [0, 90, 0],
            "scale": [2, 2, 2],
            "translation": [0, 0.5, 0]
          }
        }
      }
    ]
  }
}
